{
  "entities": {
    "Token": {
      "title": "Token",
      "description": "An access token to view the landing page",
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdBy": {
          "type": "string"
        }
      },
      "required": ["createdAt", "createdBy"]
    }
  },
  "firestore": {
    "tokens/{tokenId}": {
      "schema": {
        "$ref": "#/entities/Token"
      },
      "description": "Stores generated access tokens"
    },
    "admins/{adminId}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        },
        "required": ["email"]
      },
      "description": "List of authorized admins"
    }
  }
}
